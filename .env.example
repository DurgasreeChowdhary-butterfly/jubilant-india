# Adzuna API (free at developer.adzuna.com)
ADZUNA_APP_ID=your_id_here
ADZUNA_APP_KEY=your_key_here

# Platform cookies — copy the Cookie: header from browser DevTools
# after logging in to each site. Expire every 7-30 days.
NAUKRI_COOKIES=
LINKEDIN_COOKIES=
WELLFOUND_COOKIES=
CUTSHORT_COOKIES=
INSTAHYRE_COOKIES=
IIMJOBS_COOKIES=

# Database path (leave blank for local default)
DB_PATH=

# Scrape interval in hours (default 6)
SCRAPE_INTERVAL_HOURS=6
